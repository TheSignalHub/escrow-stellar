# Privy App ID — create a free app at https://privy.io/dashboard
# Copy this file to .env and fill in your values
VITE_PRIVY_APP_ID=your-privy-app-id-here

# DealEscrow contract address (set after deployment to Testnet)
VITE_DEAL_ESCROW_CONTRACT=CASW4L3WIFJDL2ZOBKBEMO6GV5O34DRBURRUF2EPRFFIQLJHZMSUK7IC

# Demo-only settlement token address.
# This is not Circle-issued USDC. It is a SEP-41 testnet token deployed for
# the SCF #42 Tranche 2 demo because public testnet liquidity was empty after
# reset. Escrow still demonstrates standardized settlement.
VITE_USDC_TOKEN_ADDRESS=CAHJQG77XDPFZAC7JJSRGAVYWKGEUDWOQ5O33VK4VTR2ZKOBCZAIVLFX
VITE_SETTLEMENT_TOKEN_SYMBOL=tUSDC
VITE_SETTLEMENT_TOKEN_NAME=Demo Test USD

# Soroswap testnet AMM router. The D6 swap calls this contract directly
# against the seeded XLM/demo-settlement-token pool.
VITE_SOROSWAP_ROUTER_ADDRESS=CCJUD55AG6W5HAI5LRVNKAE5WDP5XGZBUDS5WNTIVDU7O264UZZE7BRD

# Seeded Soroswap XLM/demo-settlement-token pool used by the demo route.
VITE_SOROSWAP_POOL_ADDRESS=CA4ASYDOCOJXZFB3H7O6QJ5PTDAMXORCRZN5HNE3KI7TBGS5PGR53XZ5

# Optional public REST aggregator check. This belongs on the backend, not in a
# VITE_ variable, because Vite variables are visible in browser JavaScript.
SOROSWAP_API_KEY=
