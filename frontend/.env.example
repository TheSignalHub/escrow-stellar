# Privy App ID — create a free app at https://privy.io/dashboard
# Copy this file to .env and fill in your values
VITE_PRIVY_APP_ID=your-privy-app-id-here

# DealEscrow contract address (set after deployment to Testnet)
VITE_DEAL_ESCROW_CONTRACT=CASW4L3WIFJDL2ZOBKBEMO6GV5O34DRBURRUF2EPRFFIQLJHZMSUK7IC

# USDC Testnet token address (SAC).
# The canonical Soroswap testnet USDC was wiped in a testnet reset, so we
# deploy our own SEP-41 test USDC and LP it against XLM — see
# scripts/seed-testnet-pool.sh. This is the token we seeded.
VITE_USDC_TOKEN_ADDRESS=CCFJDQ3HDXEYLS77CTS5VGJSEXXPD52PUSA65AVDSA5E5P7FMCFHKOG2

# Soroswap testnet AMM router. The D6 swap calls this contract directly
# (the Soroswap Aggregator REST API has no indexed pools on testnet post-reset).
VITE_SOROSWAP_ROUTER_ADDRESS=CCJUD55AG6W5HAI5LRVNKAE5WDP5XGZBUDS5WNTIVDU7O264UZZE7BRD

# Soroswap aggregator API key — only used by the legacy REST client
# (frontend/src/lib/soroswap.ts), kept for reference. Not needed for the
# router-direct swap path.
VITE_SOROSWAP_API_KEY=
